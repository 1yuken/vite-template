doctype html
-
  function pageLabel(f) {
    let s = String(f).trim()
    if (!s) return ''
    s = s.replace(/\/index\.html?$/i, '').replace(/\/index$/i, '').replace(/\.html$/i, '')
    s = s.replace(/^\/+|\/+$/g, '')
    return s || String(f).trim()
  }
- const pageList = pages.PageList || []
- const firstHref = pageList.length ? pageList[0].file : ''
html(lang="ru")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width,initial-scale=1")
    title= (pages.ProjectTitle || 'Страницы') + ' · dev'
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 15px;
        color: #1c1d1f;
        background: #eceef2;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      .shell {
        display: grid;
        grid-template-columns: minmax(268px, 300px) 1fr;
        gap: 0;
        min-height: 100vh;
      }
      @media (max-width: 720px) {
        .shell { grid-template-columns: 1fr; grid-template-rows: auto 1fr; }
      }
      .list {
        background: #f8f9fb;
        border-right: 1px solid #dfe3e8;
        padding: 20px 16px 24px;
        overflow: auto;
      }
      @media (max-width: 720px) {
        .list { border-right: 0; border-bottom: 1px solid #dfe3e8; max-height: 44vh; }
      }
      .list ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .row {
        display: flex;
        align-items: center;
        gap: 10px;
        min-height: 52px;
        padding: 12px 14px 12px 16px;
        border-radius: 10px;
        background: #fff;
        border: 1px solid #e6e9ef;
        box-shadow: 0 1px 0 rgba(0,0,0,0.04);
        transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
        cursor: pointer;
      }
      .row:hover {
        border-color: #cfd6e4;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }
      .row.is-active {
        border-color: #93b4fc;
        background: #f3f6ff;
        box-shadow: 0 0 0 1px rgba(37, 99, 235, 0.12);
      }
      .row a.name {
        flex: 1;
        min-width: 0;
        color: inherit;
        text-decoration: none;
        font-size: 16px;
        font-weight: 500;
        letter-spacing: 0.01em;
        line-height: 1.35;
      }
      .row a.name:hover { color: #1d4ed8; }
      .row.is-active a.name { color: #1e40af; }
      .row a.pop {
        flex: none;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        color: #64748b;
        text-decoration: none;
        font-size: 15px;
        line-height: 1;
        background: #f1f5f9;
        transition: color 0.15s ease, background 0.15s ease;
        cursor: pointer;
        position: relative;
        z-index: 1;
      }
      .row a.pop:hover {
        color: #1d4ed8;
        background: #e0e7ff;
      }
      .preview {
        display: flex;
        flex-direction: column;
        min-height: 0;
        min-height: 200px;
        padding: 20px 20px 24px;
        background: #eceef2;
      }
      .frame-inner {
        flex: 1;
        min-height: 0;
        border: 1px solid #d8dce4;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 4px 24px rgba(15, 23, 42, 0.08);
      }
      iframe {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 380px;
        border: 0;
      }
  body
    .shell
      nav.list(aria-label="Страницы")
        ul
          each pg, i in pageList
            li
              .row(class=i === 0 ? 'is-active' : '')
                a.name(href=pg.file data-role="pick")= pageLabel(pg.file)
                a.pop(href=pg.file title="Открыть страницу") ↗
      .preview
        .frame-inner
          iframe#iframe(title="Превью" src=firstHref || 'about:blank')

    script.
      (function () {
        var iframe = document.getElementById('iframe');
        var rows = document.querySelectorAll('.list .row');
        if (!iframe) return;

        function setActiveRow(row) {
          rows.forEach(function (r) { r.classList.remove('is-active'); });
          if (row) row.classList.add('is-active');
        }

        rows.forEach(function (row) {
          row.addEventListener('click', function (e) {
            if (e.target.closest('a.pop')) return;
            var link = row.querySelector('a[data-role="pick"]');
            if (!link) return;
            e.preventDefault();
            var href = link.getAttribute('href');
            if (window.matchMedia('(max-width:720px)').matches) {
              window.location.href = href;
              return;
            }
            iframe.src = href;
            setActiveRow(row);
          });
        });
      })();
